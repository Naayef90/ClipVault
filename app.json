{
  "expo": {
    "name": "ClipVault",
    "slug": "clipboard-snippet-board",
    "version": "1.0.0",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "platforms": [
      "android"
    ],
    "userInterfaceStyle": "dark",
    "android": {
      "package": "com.clipboardsnippetboard.app",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.VIBRATE",
        "android.permission.INTERNET",
        "android.permission.ACCESS_NETWORK_STATE"
      ],
      "blockedPermissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.READ_CONTACTS",
        "android.permission.CAMERA"
      ],
      "minSdkVersion": 24,
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,
      "allowBackup": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#1C1B2E"
      }
    },
    "plugins": [
      "expo-secure-store",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-5218574173760069~6588051111",
          "delayAppMeasurementInit": true
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "SnippetWidget",
              "label": "Clipboard Snippets",
              "minWidth": "180dp",
              "minHeight": "110dp",
              "description": "Show your saved snippets on the home screen",
              "previewImage": "./assets/icon.png",
              "resizeMode": "horizontal|vertical"
            },
            {
              "name": "SlimSnippetWidget",
              "label": "Clipboard Snippets (Slim)",
              "minWidth": "180dp",
              "minHeight": "50dp",
              "description": "Compact snippet widget",
              "previewImage": "./assets/icon.png",
              "resizeMode": "horizontal|vertical"
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "f07112db-56ed-42ca-94dd-99304c3e191f"
      }
    },
    "owner": "naayef"
  }
}
